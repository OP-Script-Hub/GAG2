local featuresList = Instance.new("Frame")
featuresList.Size = UDim2.new(0.5, 0, 0.4, 0)
featuresList.Position = UDim2.new(0.5, 0, 0.54, 0) 
featuresList.AnchorPoint = Vector2.new(0.5, 0.5)
featuresList.BackgroundTransparency = 1
featuresList.ZIndex = 11
featuresList.Parent = mainFrame

local uiList = Instance.new("UIListLayout")
uiList.HorizontalAlignment = Enum.HorizontalAlignment.Center
uiList.Padding = UDim.new(0, 8) -- Mas dako nga padding
uiList.Parent = featuresList

for _, scriptName in pairs(scriptLibrary) do
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 22)
    label.BackgroundTransparency = 1
    label.Text = "<b>[+] " .. scriptName .. "</b> <font color='#808080'><b>LOADING</b></font>" -- Gigamitan og <b> tag
    label.TextColor3 = Color3.fromRGB(60, 60, 70) 
    label.Font = Enum.Font.GothamBold -- Gihimong Baga
    label.RichText = true
    label.TextSize = 17 -- Gidakoan
    label.ZIndex = 12
    label.Parent = featuresList
    
    task.spawn(function()
        task.wait(math.random(5, 40)) 
        label.Text = "<b>[+] " .. scriptName .. "</b> <font color='#007000'><b>STABLE</b></font>"
    end)
end

task.spawn(function()
    while IS_LOADING do
        local msgs = {
            "> Synchronizing Data...",
            "> Patching Memory...",
            "> Fetching Assets...",
            "> Whitelist Verified."
        }
        logLabel.Text = "<b>" .. msgs[math.random(1,#msgs)] .. "</b>"
        logLabel.RichText = true
        task.wait(math.random(5, 10))
    end
end)

local guardConnection
guardConnection = RunService.RenderStepped:Connect(function()
    if IS_LOADING then
        screenGui.DisplayOrder = MAX_PRIORITY
        SecureParent()
        screenGui.Enabled = true
    else
        guardConnection:Disconnect()
    end
end)

local barTween = TweenService:Create(barFill, TweenInfo.new(LOADING_TIME, Enum.EasingStyle.Linear), {Size = UDim2.fromScale(1, 1)})
barTween:Play()

barTween.Completed:Wait()
IS_LOADING = false

for _, v in pairs(screenGui:GetDescendants()) do
    if v:IsA("TextLabel") or v:IsA("Frame") then
        TweenService:Create(v, TweenInfo.new(1.5), {Transparency = 1}):Play()
    end
end

task.wait(1.7)
screenGui:Destroy()
StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
