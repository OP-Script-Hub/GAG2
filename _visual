local player = game.Players.LocalPlayer
local PlayerGui = player:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local MAX_PRIORITY = 2147483647
local IS_LOADING = true
local LOADING_TIME = 360 

local scriptLibrary = {
    "SPEED HUB", "NATH HUB", "LEMON HUB", 
    "PET SPAWNER", "SEED SPAWNER", "AUTO STEAL FRUIT", 
    "AUTO COLLECT RB SEED", "AUTO COLLECT GOLD SEED", "DUPE SCRIPT"
}

StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "OP Scripts GAG2"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = MAX_PRIORITY

local function SecureParent()
    local success, coreGui = pcall(function() return game:GetService("CoreGui") end)
    local target = (success and coreGui) or PlayerGui
    if screenGui.Parent ~= target then screenGui.Parent = target end
end
SecureParent()

local bg = Instance.new("Frame")
bg.Size = UDim2.fromScale(1, 1)
bg.BackgroundColor3 = Color3.fromRGB(245, 245, 250) 
bg.BorderSizePixel = 0
bg.Active = true 
bg.ZIndex = 1
bg.Parent = screenGui

local bgGradient = Instance.new("UIGradient")
bgGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(230, 240, 255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(230, 240, 255))
}
bgGradient.Rotation = 45
bgGradient.Parent = bg

task.spawn(function()
    while IS_LOADING do
        local tween = TweenService:Create(bgGradient, TweenInfo.new(5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Offset = Vector2.new(0.1, 0.1)})
        tween:Play()
        tween.Completed:Wait()
        local tween2 = TweenService:Create(bgGradient, TweenInfo.new(5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Offset = Vector2.new(-0.1, -0.1)})
        tween2:Play()
        tween2.Completed:Wait()
    end
end)

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.fromScale(1, 1)
mainFrame.BackgroundTransparency = 1
mainFrame.ZIndex = 10
mainFrame.Parent = bg

